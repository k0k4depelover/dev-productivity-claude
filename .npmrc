# ============================================================
#  .npmrc — configuración npm del proyecto/global
# ============================================================

# Registro predeterminado
registry=https://registry.npmjs.org/

# Motor (fuerza versión de Node)
engine-strict=true

# Evita instalar devDependencies en producción
# omit=dev   # Descomentar para builds de producción

# Guardar exact versions
save-exact=false
save-prefix=^

# Parallelism
fund=false
audit=false
